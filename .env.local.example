# Copy to .env.local for local development.
# Start backend: cd ../prokuroBackend && docker compose up --build

GATEWAY_URL=http://localhost:3000
# Set in production so parse/analyze bypass Amplify's 30s API proxy timeout
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000

# Cognito (required for signed-in BOM APIs)
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=
# NEXT_PUBLIC_COGNITO_CLIENT_ID=
# NEXT_PUBLIC_COGNITO_REGION=us-west-2
# NEXT_PUBLIC_COGNITO_DOMAIN=

# Gateway also needs matching Cognito env vars for BOM auth:
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=
# COGNITO_REGION=us-west-2

# Local BOM persistence (gateway uses filesystem when BOM_BUCKET_NAME is unset)
# BOM_STORAGE_PATH=.data/boms
